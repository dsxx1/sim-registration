# ── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-key

# ── Flask ────────────────────────────────────────────────────
# Сгенерируй: python -c "import secrets; print(secrets.token_urlsafe(32))"
FLASK_SECRET_KEY=your-random-secret-key

# ── Telegram уведомления ─────────────────────────────────────
# Токен бота (тот же что в bot.py, из @BotFather)
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ID чата/канала куда слать уведомления
# Личный чат: узнай через @userinfobot
# Канал: -100xxxxxxxxxx (бот должен быть админом)
NOTIFICATION_CHAT_ID=123456789
